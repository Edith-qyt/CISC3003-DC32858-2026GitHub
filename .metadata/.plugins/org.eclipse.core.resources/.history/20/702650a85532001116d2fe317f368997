<script>
$(function() {
    $('.spark').each(function() {
        var valStr = $(this).data('values');
        if (!valStr) return;
        var v = valStr.split(',');
        $(this).sparkline(v, { 
            type: 'bar', 
            height: 20,
            barWidth: 3,
            barSpacing: 1,
            barColor: '#1565c0'
        });
    });
});
